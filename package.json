    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "2.4.3",
    "jose": "5.10.0",
    "next": "15.5.18",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.19.41",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.23.0",
    "eslint-config-next": "15.5.18",
    "postcss": "8.5.15",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "8.47.0",
